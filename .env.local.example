# ── Supabase (supabase.com → project settings → API) ─────────────────
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...          # server only, never expose

# ── Google Cloud OAuth client (console.cloud.google.com) ─────────────
# Enable the Gmail API (scope gmail.modify). This OAuth client is used to
# connect the single platform "Kalas" outreach mailbox that Ava sends from
# and reads vendor replies in.
#
# IMPORTANT: use a SEPARATE Google Cloud project from the one backing
# Supabase Google sign-in, owned by the Workspace org that hosts the
# mailbox, with the OAuth consent screen set to INTERNAL. Internal apps
# need no Google verification and their refresh tokens never expire on the
# 7-day testing-mode clock. (The sign-in client's consent screen must stay
# External so @gmail.com users can log in.)
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
# The admin connect callback lives here — point the redirect URI at it.
GOOGLE_REDIRECT_URI=https://your-app-url.com/api/admin/gmail/callback

# Comma-separated emails allowed to connect/reconnect the platform mailbox
# (Settings shows the admin card only to these accounts).
PLATFORM_ADMIN_EMAILS=founder@example.com

# ── Render poll worker (render.yaml → worker/poll.ts) ────────────────
# Scheduled reply polling runs as a Render Cron Job every 5 minutes — the
# app itself never polls (Netlify has no cron). The Render service needs
# exactly these six vars: NEXT_PUBLIC_SUPABASE_URL,
# SUPABASE_SERVICE_ROLE_KEY, TOKEN_ENCRYPTION_KEY, GOOGLE_CLIENT_ID,
# GOOGLE_CLIENT_SECRET, GEMINI_API_KEY.
# Run one pass locally: npx tsx --env-file=.env worker/poll.ts

# ── Gemini (aistudio.google.com → Get API key) ───────────────────────
GEMINI_API_KEY=AIza...
# Optional override for the invite design (image) model.
# GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
# Model that builds the wedding-site HTML (heavier than the chat model).
# GEMINI_HTML_MODEL=gemini-3.5-flash

# ── Jina Reader (jina.ai/reader → API key) ─────────────────────────────
# Fetches product title, image, price and store from pasted gift-registry URLs.
JINA_API_KEY=jina_...

# ── Google Places API (console.cloud.google.com → enable "Places API (New)") ──
# Verifies every suggested venue/vendor: canonical contact info, ratings,
# reviews, photos and dedupe by place id. Can be the same Google Cloud
# project as the OAuth client above; create an API key under Credentials
# and restrict it to the Places API.
GOOGLE_PLACES_API_KEY=AIza...

# ── Stripe (dashboard.stripe.com → Developers → API keys) ────────────
# Invitation print orders are paid via Stripe Checkout. The webhook must
# point at /api/webhooks/stripe and listen for checkout.session.completed
# and checkout.session.expired.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── AI website designer (optional) ───────────────────────────────────
# One-time unlock price in DKK for "Ava designs your site" (default 499).
# Set both so the server (checkout) and the builder UI (price label) agree.
# When STRIPE_SECRET_KEY is unset the feature runs unlocked (dev mode).
# WEBSITE_PRICE_DKK=499
# NEXT_PUBLIC_WEBSITE_PRICE_DKK=499

# ── App secrets ──────────────────────────────────────────────────────
TOKEN_ENCRYPTION_KEY=                     # openssl rand -hex 32
CRON_SECRET=                              # any long random string
NEXT_PUBLIC_APP_URL=https://your-app-url.com
