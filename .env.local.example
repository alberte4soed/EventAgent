# ── Supabase (supabase.com → project settings → API) ─────────────────
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...          # server only, never expose

# ── Google Cloud OAuth client (console.cloud.google.com) ─────────────
# Enable the Gmail API (scope gmail.modify). This OAuth client is used to
# connect the single platform "Kalas" outreach mailbox that Ava sends from
# and reads vendor replies in. Redirect URIs must include GOOGLE_REDIRECT_URI
# below and https://<project-ref>.supabase.co/auth/v1/callback
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
# The admin connect callback lives here — point the redirect URI at it.
GOOGLE_REDIRECT_URI=https://your-app-url.com/api/admin/gmail/callback

# Comma-separated emails allowed to connect/reconnect the platform mailbox
# (Settings shows the admin card only to these accounts).
PLATFORM_ADMIN_EMAILS=founder@example.com

# ── Gemini (aistudio.google.com → Get API key) ───────────────────────
GEMINI_API_KEY=AIza...
# Optional override for the invite design (image) model.
# GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# ── Google Places API (console.cloud.google.com → enable "Places API (New)") ──
# Verifies every suggested venue/vendor: canonical contact info, ratings,
# reviews, photos and dedupe by place id. Can be the same Google Cloud
# project as the OAuth client above; create an API key under Credentials
# and restrict it to the Places API.
GOOGLE_PLACES_API_KEY=AIza...

# ── Stripe (dashboard.stripe.com → Developers → API keys) ────────────
# Invitation print orders are paid via Stripe Checkout. The webhook must
# point at /api/webhooks/stripe and listen for checkout.session.completed
# and checkout.session.expired.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── App secrets ──────────────────────────────────────────────────────
TOKEN_ENCRYPTION_KEY=                     # openssl rand -hex 32
CRON_SECRET=                              # any long random string
NEXT_PUBLIC_APP_URL=https://your-app-url.com
